<div class="form-card-body">
    <div class="form-row-2">
        <div class="form-grp">
            {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.firstName, {'attr': {'class': 'form-control' ~ (form.firstName.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.firstName.vars.errors|length %}
                <div class="invalid-feedback">{{ form.firstName.vars.errors[0].message }}</div>
            {% endif %}
        </div>
        <div class="form-grp">
            {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.lastName, {'attr': {'class': 'form-control' ~ (form.lastName.vars.errors|length ? ' is-invalid' : '')}}) }}
            {% if form.lastName.vars.errors|length %}
                <div class="invalid-feedback">{{ form.lastName.vars.errors[0].message }}</div>
            {% endif %}
        </div>
    </div>

    <div class="form-grp">
        {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form.email.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% if form.email.vars.errors|length %}
            <div class="invalid-feedback">{{ form.email.vars.errors[0].message }}</div>
        {% endif %}
    </div>

    <div class="form-grp">
        {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control' ~ (form.plainPassword.vars.errors|length ? ' is-invalid' : '')}}) }}
        {% if form.plainPassword.vars.errors|length %}
            <div class="invalid-feedback">{{ form.plainPassword.vars.errors[0].message }}</div>
        {% endif %}
        <span class="form-hint">Minimum 8 caractères</span>
    </div>

    <div class="form-grp">
        {{ form_label(form.role, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.role, {'attr': {'class': 'form-select'}}) }}
    </div>
</div>
