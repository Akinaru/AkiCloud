<style>
    .template-layout {
        display: grid;
        grid-template-columns: 1fr 480px;
        gap: 24px;
        align-items: start;
    }
    .preview-container {
        position: sticky;
        top: calc(var(--topbar-h) + 20px);
    }
    .preview-card {
        background: var(--surface);
        border-radius: var(--r-lg);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }
    .preview-hd {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: #f8f9fd;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .preview-hd i { color: var(--blue); }
    .preview-hd span { font-weight: 700; font-size: 13px; color: var(--text); }
    .preview-body {
        padding: 24px;
        background: #f4f6fb;
        max-height: 75vh;
        overflow-y: auto;
    }

    /* Variable badge */
    .var-badge {
        background: var(--blue-light);
        color: var(--blue);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 12.5px;
    }

    /* Highlight overlay system */
    .highlight-input-wrap {
        position: relative;
    }
    .highlight-backdrop {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        pointer-events: none;
        overflow: hidden;
        border-radius: var(--r-sm);
        border: 1px solid transparent;
        padding: 8px 12px;
        z-index: 0;
    }
    .highlight-backdrop-textarea {
        overflow-y: auto;
    }
    .highlight-content {
        font-family: 'Sora', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        color: transparent;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
    .highlight-textarea-wrap .highlight-content {
        font-family: monospace;
        font-size: 13px;
    }
    .highlight-content mark {
        background: var(--blue-light);
        color: transparent;
        border-radius: 3px;
        padding: 1px 0;
    }
    .highlight-content mark.hl-bold {
        background: #fef3c7;
        color: transparent;
    }
    .highlight-content mark.hl-italic {
        background: #e0f2fe;
        color: transparent;
    }
    .highlight-content mark.hl-underline {
        background: #fce7f3;
        color: transparent;
    }
    .highlight-input {
        position: relative;
        z-index: 1;
        background: transparent !important;
    }
    .highlight-textarea {
        font-family: monospace !important;
        font-size: 13px !important;
        min-height: 200px;
        resize: vertical;
    }

    /* Simulated email — matches login / vierge style */
    .email-sim-bg {
        background: linear-gradient(to bottom, #11069f 0%, #03214D 100%);
        border-radius: 10px;
        padding: 28px 24px;
        font-family: 'Sora', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .email-sim-logo {
        text-align: center;
        margin-bottom: 24px;
    }
    .email-sim-card {
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 12px 36px rgba(15,25,50,.14), 0 4px 10px rgba(15,25,50,.07);
        overflow: hidden;
    }
    .email-sim-body {
        padding: 28px 28px 24px;
        font-size: 13.5px;
        line-height: 1.7;
        color: #151d32;
        min-height: 80px;
    }
    .email-sim-infobox {
        margin: 0 28px 24px;
        background: #f8f9fd;
        border: 1px solid #e2e6f0;
        border-radius: 10px;
        padding: 16px 20px;
    }
    .email-sim-infobox-title {
        font-weight: 700;
        font-size: 12.5px;
        color: #151d32;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
    }
    .email-sim-info-table {
        width: 100%;
        border-collapse: collapse;
    }
    .email-sim-info-table tr + tr td {
        padding-top: 6px;
    }
    .email-sim-info-label {
        font-size: 11.5px;
        color: #5c6484;
        width: 120px;
        vertical-align: top;
        padding-right: 10px;
    }
    .email-sim-info-value {
        font-size: 12px;
        color: #151d32;
        font-weight: 600;
        word-break: break-all;
    }
    .email-sim-cta {
        display: inline-flex;
        align-items: center;
        background: #11069f;
        color: #fff !important;
        text-decoration: none;
        padding: 11px 28px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: -0.2px;
    }
    .email-sim-footer {
        text-align: center;
        margin-top: 16px;
        font-size: 11px;
        color: rgba(255,255,255,.35);
        font-weight: 500;
    }

    @media (max-width: 1200px) {
        .template-layout { grid-template-columns: 1fr; }
        .preview-container { position: static; }
    }
</style>
