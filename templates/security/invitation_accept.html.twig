<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Invitation — AkiCloud</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        :root {
            --navy-950: #080e1c;
            --navy-900: #0b1628;
            --blue: #8f7ae6;
            --blue-hover: #7a64d6;
            --blue-shadow: rgba(143,122,230,.26);
            --bg: #edf0f8;
            --surface: #ffffff;
            --border: #e2e6f0;
            --border-strong: #cdd1e0;
            --text: #151d32;
            --text-2: #5c6484;
            --text-3: #9aa0bc;
            --red: #EF3340;
            --red-bg: #fff0f0;
            --r-sm: 6px;
            --r-md: 10px;
            --r-lg: 14px;
            --shadow-lg: 0 12px 36px rgba(15,25,50,.14), 0 4px 10px rgba(15,25,50,.07);
            --t: all .16s cubic-bezier(.4,0,.2,1);
            --font: 'Sora', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font);
            background: linear-gradient(160deg, #2e2550 0%, #6f5bcf 52%, #9788df 100%);
            color: var(--text);
            font-size: 14px;
            line-height: 1.55;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .inv-wrapper {
            width: 100%;
            max-width: 500px;
            padding: 20px;
        }

        .inv-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
        }

        .inv-logo {
            max-width: 100%;
            height: auto;
            max-height: 70px;
            object-fit: contain;
        }

        .inv-card {
            width: 100%;
            background: var(--surface);
            border-radius: var(--r-lg);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }

        .inv-card-hd {
            padding: 28px 28px 0;
            text-align: center;
        }

        .inv-card-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 4px;
        }

        .inv-card-sub {
            font-size: 13px;
            color: var(--text-2);
        }

        .inv-card-body {
            padding: 24px 28px 28px;
        }

        .inv-error {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            background: var(--red-bg);
            border: 1px solid #fde;
            border-radius: var(--r-sm);
            margin-bottom: 18px;
            font-size: 13px;
            color: var(--red);
            font-weight: 500;
        }

        .inv-error i { font-size: 16px; flex-shrink: 0; }

        .form-grp {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-bottom: 16px;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .form-control {
            width: 100%;
            padding: 10px 13px;
            border: 1.5px solid var(--border);
            border-radius: var(--r-sm);
            font-size: 13.5px;
            font-family: var(--font);
            color: var(--text);
            background: var(--surface);
            transition: var(--t);
            outline: none;
        }

        .form-control:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(143,122,230,.18);
        }

        .form-control::placeholder { color: var(--text-3); }

        .invalid-feedback {
            margin-top: 2px;
            font-size: 12px;
            color: var(--red);
        }

        .row-2 {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .btn-login {
            width: 100%;
            padding: 11px 18px;
            background: var(--blue);
            color: #fff;
            border: none;
            border-radius: var(--r-sm);
            font-size: 14px;
            font-weight: 600;
            font-family: var(--font);
            cursor: pointer;
            transition: var(--t);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-login:hover {
            background: var(--blue-hover);
            box-shadow: 0 2px 10px var(--blue-shadow);
        }

        .btn-login i { font-size: 16px; }

        .inv-meta {
            margin-top: 14px;
            color: var(--text-2);
            font-size: 12px;
            text-align: center;
        }

        .inv-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: rgba(255,255,255,.3);
        }

        a { color: var(--blue); text-decoration: none; }

        @media (max-width: 640px) { .row-2 { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<div class="inv-wrapper">
    <div class="inv-brand">
        <img src="{{ asset('img/Logo_AKI.png') }}" alt="Logo AKI" class="inv-logo">
    </div>

    <div class="inv-card">
        <div class="inv-card-hd">
            <div class="inv-card-title">Créer votre compte</div>
            {% if invitation and invitation.email %}
                <div class="inv-card-sub">Invitation envoyée à {{ invitation.email }}</div>
            {% else %}
                <div class="inv-card-sub">Finalisez votre accès à AkiCloud</div>
            {% endif %}
        </div>
        <div class="inv-card-body">
            {% if isInvalid %}
                <div class="inv-error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>Ce lien d'invitation est invalide, expiré ou déjà utilisé.</span>
                </div>
                <div class="inv-meta">
                    Demandez une nouvelle invitation à l'administrateur, puis reconnectez-vous depuis la page <a href="{{ path('app_login') }}">connexion</a>.
                </div>
            {% else %}
                {{ form_start(form) }}
                    <div class="row-2">
                        <div class="form-grp">
                            {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
                            {% if form.firstName.vars.errors|length %}
                                <div class="invalid-feedback">{{ form.firstName.vars.errors[0].message }}</div>
                            {% endif %}
                        </div>
                        <div class="form-grp">
                            {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
                            {% if form.lastName.vars.errors|length %}
                                <div class="invalid-feedback">{{ form.lastName.vars.errors[0].message }}</div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="form-grp">
                        {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                        {% if form.plainPassword.first.vars.errors|length %}
                            <div class="invalid-feedback">{{ form.plainPassword.first.vars.errors[0].message }}</div>
                        {% endif %}
                    </div>
                    <div class="form-grp">
                        {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                        {% if form.plainPassword.second.vars.errors|length %}
                            <div class="invalid-feedback">{{ form.plainPassword.second.vars.errors[0].message }}</div>
                        {% endif %}
                        {% if form.plainPassword.vars.errors|length %}
                            <div class="invalid-feedback">{{ form.plainPassword.vars.errors[0].message }}</div>
                        {% endif %}
                    </div>

                    <button class="btn-login" type="submit">
                        <i class="bi bi-person-check"></i>
                        Créer mon compte
                    </button>
                    <div class="inv-meta">
                        L'invitation expire le {{ invitation.expiresAt|date('d/m/Y à H:i') }}.
                    </div>
                {{ form_end(form) }}
            {% endif %}
        </div>
    </div>

    <div class="inv-footer">AkiCloud — Infrastructure Cloud pour étudiants</div>
</div>
</body>
</html>
