{% extends 'base.html.twig' %}

{% block title %}{{ site.name }}{% endblock %}

{% block stylesheets %}
<style>
    .sidebar,
    .sidebar-overlay,
    .topbar {
        display: none !important;
    }
    .main {
        margin-left: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
    }
    .content {
        padding: 0 !important;
        max-width: 100% !important;
    }

    .mo-page {
        min-height: 100vh;
        background:
            radial-gradient(circle at 10% 0%, rgba(143,122,230,.2), transparent 34%),
            radial-gradient(circle at 90% 100%, rgba(111,91,207,.14), transparent 38%),
            #f3f4fb;
    }

    .mo-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 18px 20px 30px;
    }

    .mo-header {
        border: 1px solid #dddff0;
        border-radius: 18px;
        background: rgba(255,255,255,.78);
        backdrop-filter: blur(6px);
        box-shadow: 0 10px 30px rgba(28,32,64,.08);
        padding: 10px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 16px;
    }

    .mo-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .mo-brand img {
        height: 46px;
        width: auto;
    }

    .mo-brand-title {
        font-size: 18px;
        font-weight: 800;
        color: #181f37;
    }

    .mo-nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .mo-link {
        height: 38px;
        border: 1px solid #d8dbeb;
        border-radius: 10px;
        background: #fff;
        color: #313a60;
        padding: 0 12px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 700;
        transition: all .15s ease;
    }

    .mo-link:hover {
        border-color: #8f7ae6;
        color: #8f7ae6;
    }

    .mo-link.primary {
        background: #8f7ae6;
        border-color: #8f7ae6;
        color: #fff;
    }

    .mo-wrap {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 14px;
    }

    .mo-card {
        border: 1px solid #dfe3f2;
        border-radius: 16px;
        background: #fff;
        box-shadow: 0 10px 22px rgba(21,30,54,.06);
        overflow: hidden;
    }

    .mo-hd {
        padding: 16px 18px;
        border-bottom: 1px solid #edf0f7;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
    }

    .mo-title {
        font-size: 24px;
        font-weight: 900;
        color: #171d34;
        margin-bottom: 4px;
    }

    .mo-sub {
        color: #6b57c6;
        font-size: 13px;
        word-break: break-all;
    }

    .mo-chip {
        border-radius: 999px;
        border: 1px solid rgba(143,122,230,.38);
        background: #f3efff;
        color: #6f5bcf;
        font-size: 11px;
        font-weight: 800;
        padding: 5px 10px;
    }

    .mo-bd {
        padding: 16px 18px 17px;
    }

    .mo-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 9px;
    }

    .mo-box {
        border: 1px solid #eceff8;
        border-radius: 10px;
        background: #fafbff;
        padding: 9px 10px;
    }

    .mo-k {
        font-size: 10px;
        text-transform: uppercase;
        color: #9aa0bc;
        font-weight: 700;
        letter-spacing: .5px;
    }

    .mo-v {
        margin-top: 3px;
        font-size: 12px;
        color: #1f2744;
        font-weight: 800;
    }

    .mo-v.mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .mo-actions {
        margin-top: 13px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .mo-note {
        font-size: 14px;
        color: #5f6784;
        line-height: 1.55;
    }

    @media (max-width: 980px) {
        .mo-wrap {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 760px) {
        .mo-shell {
            padding: 12px 12px 24px;
        }

        .mo-header {
            flex-direction: column;
            align-items: stretch;
        }

        .mo-brand {
            justify-content: center;
        }

        .mo-nav .mo-link {
            flex: 1;
            justify-content: center;
        }

        .mo-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="mo-page">
    <div class="mo-shell">
        <header class="mo-header">
            <div class="mo-brand">
                <img src="{{ asset('img/Logo-AKI-Off.png') }}" alt="AKI">
                <div class="mo-brand-title">AkiCloud</div>
            </div>
            <nav class="mo-nav">
                <a class="mo-link" href="{{ path('app_middle_office') }}"><i class="bi bi-grid-1x2"></i>Mes sites</a>
                <a class="mo-link" href="{{ path('app_profile') }}"><i class="bi bi-person"></i>Mon profil</a>
                <a class="mo-link primary" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i>Déconnexion</a>
            </nav>
        </header>

        <div class="mo-wrap">
            <section class="mo-card">
                <div class="mo-hd">
                    <div>
                        <h1 class="mo-title">{{ site.name }}</h1>
                        <div class="mo-sub">{{ site.customDomain ?: site.getFullUrl(base_domain) }}</div>
                    </div>
                    <span class="mo-chip">{{ site.type|upper }}</span>
                </div>
                <div class="mo-bd">
                    <div class="mo-grid">
                        <div class="mo-box">
                            <div class="mo-k">Statut</div>
                            <div class="mo-v">{{ site.status|capitalize }}</div>
                        </div>
                        <div class="mo-box">
                            <div class="mo-k">Port</div>
                            <div class="mo-v">{{ site.port ?: '—' }}</div>
                        </div>
                        <div class="mo-box">
                            <div class="mo-k">Sous-domaine</div>
                            <div class="mo-v">{{ site.subdomain ?: '—' }}</div>
                        </div>
                        <div class="mo-box">
                            <div class="mo-k">ID site</div>
                            <div class="mo-v">#{{ site.id }}</div>
                        </div>
                        <div class="mo-box">
                            <div class="mo-k">Base de données</div>
                            <div class="mo-v mono">{{ site.dbName ?: 'Non configurée' }}</div>
                        </div>
                        <div class="mo-box">
                            <div class="mo-k">Hôte DB</div>
                            <div class="mo-v mono">{{ site.dbHost ?: '—' }}</div>
                        </div>
                    </div>
                    <div class="mo-actions">
                        <a href="https://{{ site.customDomain ?: site.getFullUrl(base_domain) }}" target="_blank" class="btn btn-primary">
                            <i class="bi bi-box-arrow-up-right"></i>Ouvrir le site
                        </a>
                        <a href="{{ path('app_middle_office') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i>Retour
                        </a>
                    </div>
                </div>
            </section>

            <aside class="mo-card">
                <div class="mo-hd">
                    <h2 class="mo-title" style="font-size:18px; margin:0;">Contexte</h2>
                </div>
                <div class="mo-bd">
                    <p class="mo-note">Tu es dans une vue middle-office orientée utilisation. Les fonctions d'administration et de déploiement restent côté back-office.</p>
                    <div class="mo-grid" style="margin-top:10px;">
                        <div class="mo-box">
                            <div class="mo-k">Source</div>
                            <div class="mo-v">{{ site.deploymentSource == 'git_public' ? 'Git public' : 'Volume local' }}</div>
                        </div>
                        <div class="mo-box">
                            <div class="mo-k">Repository</div>
                            <div class="mo-v mono">{{ site.gitRepository ?: '—' }}</div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>
{% endblock %}
