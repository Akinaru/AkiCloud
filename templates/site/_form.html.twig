{% set isNewSiteForm = app.request.attributes.get('_route') == 'app_site_new' %}
<style>
    .access-block {
        border: 1px solid var(--border);
        background: #f8f9fd;
        border-radius: 12px;
        padding: 14px 16px;
        margin-top: 14px;
    }
    .access-block-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }
    .access-panel-title {
        font-weight: 700;
        font-size: 13px;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .access-panel-count {
        font-size: 11px;
        font-weight: 700;
        color: var(--blue);
        background: #ece8ff;
        border: 1px solid rgba(143,122,230,.35);
        border-radius: 999px;
        padding: 2px 8px;
    }
    .access-block .form-select {
        min-height: 220px;
    }
    .access-block-hint {
        margin-top: 8px;
        font-size: 12px;
        color: var(--text-2);
        line-height: 1.45;
    }
    .ua-manager {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }
    .ua-col {
        border: 1px solid var(--border);
        border-radius: 10px;
        background: #fff;
        min-height: 260px;
        display: flex;
        flex-direction: column;
    }
    .ua-col-hd {
        padding: 10px 12px;
        border-bottom: 1px solid var(--border);
        font-size: 12px;
        font-weight: 700;
        color: var(--text);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }
    .ua-search-wrap {
        padding: 10px 12px;
        border-bottom: 1px solid var(--border);
    }
    .ua-search {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 12px;
        background: #fff;
        color: var(--text);
        outline: none;
    }
    .ua-search:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(143,122,230,.16);
    }
    .ua-list {
        list-style: none;
        margin: 0;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        overflow: auto;
        flex: 1;
    }
    .ua-item {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 8px 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        background: #fbfcff;
    }
    .ua-item-main {
        min-width: 0;
    }
    .ua-item-name {
        font-size: 12.5px;
        font-weight: 700;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ua-item-email {
        font-size: 11.5px;
        color: var(--text-2);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ua-item-btn {
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-2);
        border-radius: 7px;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
    }
    .ua-item-btn:hover {
        border-color: var(--blue);
        color: var(--blue);
    }
    .ua-item-btn.danger:hover {
        border-color: var(--red);
        color: var(--red);
    }
    .ua-tools {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 10px;
    }
    @media (max-width: 980px) {
        .ua-manager {
            grid-template-columns: 1fr;
        }
    }
</style>

{% if isNewSiteForm %}
<style>
    .wizard {
        display: grid;
        gap: 18px;
    }
    .wizard-steps {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        padding: 0 24px 18px 24px;
        border-bottom: 1px solid var(--border);
    }
    .wizard-step {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 10px;
        background: #f8f9fd;
        color: var(--text-2);
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: .15s ease;
    }
    .wizard-step-num {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 11px;
        background: #fff;
        flex-shrink: 0;
    }
    .wizard-step.active {
        border-color: rgba(143,122,230,.45);
        background: #f1edff;
        color: var(--text);
    }
    .wizard-step.active .wizard-step-num {
        background: var(--blue);
        color: #fff;
        border-color: var(--blue);
    }
    .wizard-pane {
        display: none;
    }
    .wizard-pane.active {
        display: block;
    }
    .wizard-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 0 24px 24px 24px;
    }
    .wizard-actions-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .wizard-local-box {
        padding: 14px 16px;
        background: #f8f9fd;
        border-radius: 12px;
        border: 1px solid var(--border);
        margin-top: 8px;
        display: none;
    }
    @media (max-width: 900px) {
        .wizard-steps {
            grid-template-columns: 1fr;
        }
    }
</style>

