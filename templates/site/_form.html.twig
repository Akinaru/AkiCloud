            </button>
            <button type="submit" class="btn btn-primary" id="wizard-submit" style="display:none;">
                <i class="bi bi-check-lg"></i>{{ button_label|default('Créer le site') }}
            </button>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const totalSteps = 3;
    let currentStep = 1;

    const prevBtn = document.getElementById('wizard-prev');
    const nextBtn = document.getElementById('wizard-next');
    const submitBtn = document.getElementById('wizard-submit');
    const sourceSelect = document.getElementById('{{ form.deploymentSource.vars.id }}');
    const gitPanel = document.getElementById('git-source-fields');
    const localPanel = document.getElementById('local-volume-panel');
    const gitInput = document.getElementById('{{ form.gitRepository.vars.id }}');

    const ownerToggle = document.querySelector('input[type="checkbox"][name$="[ownerDifferent]"]');
    const ownerPanel = document.getElementById('owner-fields-panel');
    const authorizedSelect = document.getElementById('{{ form.authorizedUsers.vars.id }}');
    const authorizedCount = document.getElementById('authorized-count-new');

    function syncOwnerPanel() {
        if (!ownerToggle || !ownerPanel) return;
        ownerPanel.style.display = ownerToggle.checked ? 'block' : 'none';
    }

    function syncSourcePanels() {
        if (!sourceSelect) return;
        const isLocal = sourceSelect.value === 'local_volume';
        if (gitPanel) gitPanel.style.display = isLocal ? 'none' : '';
        if (localPanel) localPanel.style.display = isLocal ? 'block' : 'none';
        if (gitInput) gitInput.required = !isLocal;
    }

    function syncAuthorizedCount() {
        if (!authorizedSelect || !authorizedCount) return;
        const selected = Array.from(authorizedSelect.selectedOptions).length;
        authorizedCount.textContent = selected > 1 ? `${selected} sélectionnés` : `${selected} sélectionné`;
    }

    function renderStep() {
        document.querySelectorAll('[data-step-pane]').forEach(function (pane) {
            pane.classList.toggle('active', Number(pane.dataset.stepPane) === currentStep);
        });
        document.querySelectorAll('[data-step-indicator]').forEach(function (item) {
            item.classList.toggle('active', Number(item.dataset.stepIndicator) === currentStep);
        });

        if (prevBtn) prevBtn.style.display = currentStep === 1 ? 'none' : '';
        if (nextBtn) nextBtn.style.display = currentStep === totalSteps ? 'none' : '';
        if (submitBtn) submitBtn.style.display = currentStep === totalSteps ? '' : 'none';
    }

    function validateStep(step) {
        if (step === 1) {
            const name = document.getElementById('{{ form.name.vars.id }}');
            const type = document.getElementById('{{ form.type.vars.id }}');
            return !!(name && name.value.trim() && type && type.value.trim());
        }
        if (step === 2) {
            if (sourceSelect && sourceSelect.value === 'git_public') {
                return !!(gitInput && gitInput.value.trim());
            }
        }
        return true;
    }

    if (nextBtn) {
        nextBtn.addEventListener('click', function () {
            if (!validateStep(currentStep)) {
                alert('Merci de compléter les champs requis avant de continuer.');
                return;
            }
            if (currentStep < totalSteps) {
                currentStep += 1;
                renderStep();
            }
        });
    }

    if (prevBtn) {
        prevBtn.addEventListener('click', function () {
            if (currentStep > 1) {
                currentStep -= 1;
                renderStep();
            }
        });
    }

    syncOwnerPanel();
    syncSourcePanels();
    syncAuthorizedCount();
    renderStep();

    if (ownerToggle) ownerToggle.addEventListener('change', syncOwnerPanel);
    if (sourceSelect) sourceSelect.addEventListener('change', syncSourcePanels);
    if (authorizedSelect) authorizedSelect.addEventListener('change', syncAuthorizedCount);
});
</script>

