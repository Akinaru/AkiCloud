</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const nativeSelect = document.getElementById('{{ form.authorizedUsers.vars.id }}');
    const mainCount = document.getElementById('authorized-count-edit');
    const availableCount = document.getElementById('ua-available-count');
    const selectedCount = document.getElementById('ua-selected-count');
    const availableList = document.getElementById('ua-available-list');
    const selectedList = document.getElementById('ua-selected-list');
    const searchInput = document.getElementById('ua-search');
    const addFilteredBtn = document.getElementById('ua-add-filtered');
    const clearAllBtn = document.getElementById('ua-clear-all');

    if (!nativeSelect || !mainCount || !availableList || !selectedList) return;

    const users = Array.from(nativeSelect.options).map(function (option) {
        const label = option.textContent || '';
        const match = label.match(/^(.*)\s+\(([^)]+)\)$/);
        const name = match ? match[1] : label;
        const email = match ? match[2] : '';
        return {
            value: option.value,
            name: name,
            email: email,
            search: (name + ' ' + email).toLowerCase()
        };
    });

    function setSelected(userId, selected) {
        const option = Array.from(nativeSelect.options).find(function (opt) { return opt.value === userId; });
        if (option) option.selected = selected;
    }

    function isSelected(userId) {
        const option = Array.from(nativeSelect.options).find(function (opt) { return opt.value === userId; });
        return !!option && option.selected;
    }

    function getSearchTerm() {
        return (searchInput?.value || '').trim().toLowerCase();
    }

    function escapeHtml(value) {
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function renderLists() {
        const term = getSearchTerm();
        const available = users.filter(function (u) { return !isSelected(u.value) && (term === '' || u.search.includes(term)); });
        const selected = users.filter(function (u) { return isSelected(u.value); });

        availableList.innerHTML = available.map(function (u) {
            return `
                <li class="ua-item">
                    <div class="ua-item-main">
                        <div class="ua-item-name">${escapeHtml(u.name)}</div>
                        <div class="ua-item-email">${escapeHtml(u.email)}</div>
                    </div>
                    <button type="button" class="ua-item-btn" data-action="add" data-user="${u.value}" title="Ajouter">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </li>
            `;
        }).join('');

        selectedList.innerHTML = selected.map(function (u) {
            return `
                <li class="ua-item">
                    <div class="ua-item-main">
                        <div class="ua-item-name">${escapeHtml(u.name)}</div>
                        <div class="ua-item-email">${escapeHtml(u.email)}</div>
                    </div>
                    <button type="button" class="ua-item-btn danger" data-action="remove" data-user="${u.value}" title="Retirer">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </li>
            `;
        }).join('');

        mainCount.textContent = selected.length > 1 ? `${selected.length} sélectionnés` : `${selected.length} sélectionné`;
        if (availableCount) availableCount.textContent = String(available.length);
        if (selectedCount) selectedCount.textContent = String(selected.length);
    }

    availableList.addEventListener('click', function (event) {
        const btn = event.target.closest('[data-action="add"]');
        if (!btn) return;
        setSelected(btn.getAttribute('data-user'), true);
        renderLists();
    });

    selectedList.addEventListener('click', function (event) {
        const btn = event.target.closest('[data-action="remove"]');
        if (!btn) return;
        setSelected(btn.getAttribute('data-user'), false);
        renderLists();
    });

    searchInput?.addEventListener('input', renderLists);

    addFilteredBtn?.addEventListener('click', function () {
        const term = getSearchTerm();
        users.forEach(function (u) {
            if (!isSelected(u.value) && (term === '' || u.search.includes(term))) {
                setSelected(u.value, true);
            }
        });
        renderLists();
    });

    clearAllBtn?.addEventListener('click', function () {
        users.forEach(function (u) { setSelected(u.value, false); });
        renderLists();
    });

    renderLists();
});
</script>

{% endif %}

{{ form_end(form) }}
