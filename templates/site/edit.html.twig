{% extends 'base.html.twig' %}

{% block title %}Éditer — {{ site.name }}{% endblock %}

{% block breadcrumb %}
    <span class="bc-item">AkiCloud</span>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <a href="{{ path('app_site_index') }}" class="bc-item" style="text-decoration:none">Sites</a>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <a href="{{ path('app_site_show', {'id': site.id}) }}" class="bc-item" style="text-decoration:none">{{ site.name }}</a>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <span class="bc-item current">Éditer</span>
{% endblock %}

{% block body %}
    <a href="{{ path('app_site_show', {'id': site.id}) }}" class="back-link">
        <i class="bi bi-arrow-left"></i>Retour au site
    </a>

    <div class="page-hd">
        <div>
            <div class="page-title">Éditer — {{ site.name }}</div>
            <div class="page-sub">Modifiez les informations de l'instance #{{ site.id }}.</div>
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-hd">
            <div class="form-card-title"><i class="bi bi-pencil-square" style="color:var(--blue);margin-right:8px"></i>Modifier les informations</div>
            <div class="form-card-sub">Les modifications seront appliquées immédiatement.</div>
        </div>
        {{ include('site/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>

    <div class="danger-zone">
        <div class="danger-zone-hd">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span class="danger-zone-title">Zone de danger</span>
        </div>
        <div class="danger-zone-body">
            <p class="danger-desc">
                La suppression de ce site est <strong>permanente et irréversible</strong>.<br>
                Toutes les données associées seront définitivement perdues.
            </p>
            <button class="btn btn-danger" style="flex-shrink:0" onclick="document.getElementById('modal-delete').classList.add('open')">
                <i class="bi bi-trash3"></i>Supprimer
            </button>
        </div>
    </div>

    <!-- Delete modal -->
    <div class="modal-bg" id="modal-delete">
        <div class="modal-box">
            <div class="modal-ico"><i class="bi bi-trash3-fill"></i></div>
            <div class="modal-title">Supprimer ce site ?</div>
            <p class="modal-desc">
                Vous êtes sur le point de supprimer définitivement le site
                <strong>{{ site.name }}</strong>. Cette action est irréversible.
            </p>
            <div class="modal-acts">
                <button class="btn btn-secondary" onclick="document.getElementById('modal-delete').classList.remove('open')">
                    Annuler
                </button>
                {{ include('site/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
