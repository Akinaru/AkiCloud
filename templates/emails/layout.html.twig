<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ email_title|default('AkiCloud') }}</title>
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            padding: 0;
            background: #f1edff;
            font-family: 'Sora', 'Segoe UI', Arial, sans-serif;
            color: #1c1830;
            overflow-x: hidden;
            width: 100% !important;
        }
        .wrapper {
            width: 100%;
            max-width: 100%;
            padding: 16px 6px;
            background: radial-gradient(circle at 20% 10%, #9687de 0%, #6f5bcf 38%, #322954 100%);
            overflow-x: hidden;
        }
        .top-logo {
            text-align: center;
            margin: 0 auto 14px auto;
        }
        .top-logo img {
            display: inline-block;
            max-width: 160px;
            width: 100%;
            height: auto;
        }
        .container {
            width: 100%;
            max-width: 520px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #e4def8;
            border-radius: 16px;
            overflow: hidden;
        }
        .head {
            padding: 18px 16px 14px 16px;
            border-bottom: 1px solid #f0eafe;
            text-align: center;
        }
        .title {
            margin: 0;
            font-size: 24px;
            line-height: 1.2;
            color: #1c1830;
        }
        .body {
            padding: 20px 16px;
            color: #5f577e;
            font-size: 15px;
            line-height: 1.65;
        }
        .body p {
            margin: 0 0 14px 0;
        }
        .cta {
            display: inline-block;
            margin: 12px auto 12px auto;
            padding: 11px 18px;
            background: #8f7ae6;
            border-radius: 10px;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
        }
        .note {
            margin-top: 18px;
            border: 1px solid #e4def8;
            background: #f8f5ff;
            border-radius: 12px;
            padding: 14px;
            font-size: 13px;
            color: #5f577e;
        }
        .foot {
            padding: 12px 16px 16px 16px;
            color: #9b92bf;
            font-size: 12px;
            text-align: center;
        }
        .muted {
            color: #9b92bf;
            font-size: 12px;
            word-break: break-all;
        }
        @media only screen and (max-width: 560px) {
            .wrapper {
                padding: 12px 4px;
            }
            .container {
                max-width: 100%;
            }
            .title {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
<div class="wrapper">
    <div class="top-logo">
        <img src="{{ absolute_url(asset('img/Logo_AKI.png')) }}" alt="AkiCloud">
    </div>
    <div class="container">
        <div class="head">
            {% block head %}{% endblock %}
        </div>
        <div class="body">
            {% block body %}{% endblock %}
        </div>
        <div class="foot">
            {% block footer %}Propulsé par AkiCloud{% endblock %}
        </div>
    </div>
</div>
</body>
</html>
